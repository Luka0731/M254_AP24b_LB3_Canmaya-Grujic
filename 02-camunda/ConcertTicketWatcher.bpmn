    <bpmn:sequenceFlow id="Flow_1ckxn52" sourceRef="Gateway_OtherUsersInvited-User" targetRef="CatchEvent_WaitForInvitationResult">
      <bpmn:conditionExpression>${inviteeUsernames != null &amp;&amp; !inviteeUsernames.trim().isEmpty()}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0566m1n" name="no" sourceRef="ExclusiveGateway_GoingToConcert-User" targetRef="EndEvent_UserDeclinedConcert-User">
      <bpmn:conditionExpression>${isGoing == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1kquxeh" sourceRef="CatchEvent_WaitForConcertAnnounced" targetRef="UserTask_FillInConcertSettingsForum" />
    <bpmn:sequenceFlow id="Flow_148b2h9" sourceRef="ThrowEvent_SystemStart" targetRef="CatchEvent_WaitForConcertAnnounced" />
    <bpmn:userTask id="UserTask_StartNewArtistWatch" name="Start new Artist Watch" camunda:formRef="StartNewArtistWatch" camunda:formRefBinding="latest" camunda:assignee="demo">
