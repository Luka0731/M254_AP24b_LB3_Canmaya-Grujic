    {
      "content": "<h3>{{eventName}}</h3>\n<p>Location: {{eventVenue}}, {{eventCity}}</p>\n<p>Date: {{eventDate}}</p>\n<p>Price: {{eventPrice}}</p>\n<a href=\"{{eventUrl}}\" target=\"_blank\">Click here to buy tickets or to find out more about the Event!</a>",
